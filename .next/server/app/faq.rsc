5:["$","div","Can I dispute credit report errors myself?",{"style":{"background":"rgba(255,255,255,.94)","border":"1px solid #cfeee0","borderRadius":8,"padding":20,"boxShadow":"0 18px 42px rgba(16,32,51,.07)"},"children":[["$","h2",null,{"style":{"marginTop":0},"children":"Can I dispute credit report errors myself?"}],["$","p",null,{"style":{"color":"#475569","lineHeight":1.65},"children":"Yes. You can dispute inaccurate or incomplete information directly with credit bureaus and furnishers at no cost."}]]}]
6:["$","div","Do accurate negative accounts come off?",{"style":{"background":"rgba(255,255,255,.94)","border":"1px solid #cfeee0","borderRadius":8,"padding":20,"boxShadow":"0 18px 42px rgba(16,32,51,.07)"},"children":[["$","h2",null,{"style":{"marginTop":0},"children":"Do accurate negative accounts come off?"}],["$","p",null,{"style":{"color":"#475569","lineHeight":1.65},"children":"Not just because they are negative. Accurate and verifiable information may remain for the legal reporting period."}]]}]
7:["$","div","Does the monthly fee include certified mail?",{"style":{"background":"rgba(255,255,255,.94)","border":"1px solid #cfeee0","borderRadius":8,"padding":20,"boxShadow":"0 18px 42px rgba(16,32,51,.07)"},"children":[["$","h2",null,{"style":{"marginTop":0},"children":"Does the monthly fee include certified mail?"}],["$","p",null,{"style":{"color":"#475569","lineHeight":1.65},"children":"Not automatically. Postage, certified mail, printing, report access, credit monitoring, identity verification, and attorney review should be listed separately unless your plan says they are included."}]]}]
8:["$","div","Are texts and emails sent in this preview?",{"style":{"background":"rgba(255,255,255,.94)","border":"1px solid #cfeee0","borderRadius":8,"padding":20,"boxShadow":"0 18px 42px rgba(16,32,51,.07)"},"children":[["$","h2",null,{"style":{"marginTop":0},"children":"Are texts and emails sent in this preview?"}],["$","p",null,{"style":{"color":"#475569","lineHeight":1.65},"children":"No. The launch preview shows queued portal, email, and text style updates without sending real messages."}]]}]
9:["$","div","Can I upload reports manually?",{"style":{"background":"rgba(255,255,255,.94)","border":"1px solid #cfeee0","borderRadius":8,"padding":20,"boxShadow":"0 18px 42px rgba(16,32,51,.07)"},"children":[["$","h2",null,{"style":{"marginTop":0},"children":"Can I upload reports manually?"}],["$","p",null,{"style":{"color":"#475569","lineHeight":1.65},"children":"Yes. The launch preview supports manual report upload and manual staff review status."}]]}]
