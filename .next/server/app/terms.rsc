5:["$","p",null,{"children":"Credit Vivo provides a portal for credit report upload, customer-friendly findings, document organization, dispute workflow tracking, and educational guidance. Backend scanner rules are internal and are not shown as legal conclusions to customers."}]
6:["$","div","No guaranteed result",{"children":[["$","h2",null,{"style":{"fontSize":22,"marginBottom":6},"children":"No guaranteed result"}],["$","p",null,{"children":"Credit Vivo does not guarantee deletion of accounts, removal of accurate information, loan approval, credit score increases, or a specific timeline. Accurate negative information may remain on a credit report."}]]}]
7:["$","div","Customer responsibilities",{"children":[["$","h2",null,{"style":{"fontSize":22,"marginBottom":6},"children":"Customer responsibilities"}],["$","p",null,{"children":"You agree to provide truthful information, review documents before they are sent, keep login information secure, and notify Credit Vivo about bureau or furnisher responses you receive."}]]}]
8:["$","div","Payments and third-party costs",{"children":[["$","h2",null,{"style":{"fontSize":22,"marginBottom":6},"children":"Payments and third-party costs"}],["$","p",null,{"children":"Monthly fees do not automatically include certified mail, postage, credit monitoring, identity verification, attorney review, third-party report access, or court/legal costs unless a written plan says they are included."}]]}]
9:["$","div","Electronic communications",{"children":[["$","h2",null,{"style":{"fontSize":22,"marginBottom":6},"children":"Electronic communications"}],["$","p",null,{"children":"By choosing portal, email, or text updates, you consent to electronic communications about your account. Message and data rates may apply. You may change preferences in the portal or by contacting support."}]]}]
a:["$","div","Attorney services",{"children":[["$","h2",null,{"style":{"fontSize":22,"marginBottom":6},"children":"Attorney services"}],["$","p",null,{"children":"Attorney backup or escalation is available only when offered through a separate compliant arrangement. Credit Vivo does not provide legal advice unless an attorney-client relationship is separately created."}]]}]
b:["$","div","Cancellation",{"children":[["$","h2",null,{"style":{"fontSize":22,"marginBottom":6},"children":"Cancellation"}],["$","p",null,{"children":"Paid service agreements should include the cancellation rights required by federal and state law. Credit Vivo should not charge for credit repair services before legally permitted under the applicable agreement."}]]}]
